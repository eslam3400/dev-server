# Traefik
DOMAIN=example.com
ACME_EMAIL=admin@example.com
# Dashboard basic-auth user. Generate the bcrypt hash with:
#   docker run --rm httpd:alpine htpasswd -nbB admin yourpassword
# IMPORTANT: every literal $ in the hash MUST be doubled to $$ here, because
# docker compose interpolates this value into the label and treats a single $
# as a variable reference (eating part of the hash). compose turns $$ back into
# a single $. Do NOT `source` this file into your shell — compose reads it
# directly, and sourcing would mangle any value containing $.
TRAEFIK_DASHBOARD_USERS=admin:$$2y$$05$$...

# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db

# MongoDB
MONGO_ROOT_USER=user
MONGO_ROOT_PASSWORD=password
MONGO_DB=db

# Redis
REDIS_PASSWORD=password

# RustFS
RUSTFS_ACCESS_KEY=access
RUSTFS_SECRET_KEY=secret
