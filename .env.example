# Traefik
DOMAIN=example.com
ACME_EMAIL=admin@example.com
# Generate the password hash with:
#   docker run --rm httpd:alpine htpasswd -nbB admin yourpassword
# Use single $ here — double $$ is only needed when the value is hardcoded
# directly inside compose.yaml labels, not when it comes from .env.
TRAEFIK_DASHBOARD_USERS=admin:$2y$05$...

# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db

# MongoDB
MONGO_ROOT_USER=user
MONGO_ROOT_PASSWORD=password
MONGO_DB=db

# Redis
REDIS_PASSWORD=password

# RustFS
RUSTFS_ACCESS_KEY=access
RUSTFS_SECRET_KEY=secret
